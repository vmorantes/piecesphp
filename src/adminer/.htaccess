RewriteEngine off

Options -Indexes

#Prohibir acceso a algunos archivos
<FilesMatch "\.(sass|scss|htaccess|php|gitignore|sqlite|sqlite3|db|sdb)$">
	<IfVersion >= 2.4>
		Require all denied
	</IfVersion>
	<IfVersion < 2.4>
		Order deny,allow
		Deny from All
	</IfVersion>
</FilesMatch>

#Permitir acceso php solo a index.php
<FilesMatch "^index.php$">
	<IfVersion >= 2.4>
		Require all granted
	</IfVersion>
	<IfVersion < 2.4>
		Allow from All
	</IfVersion>
</FilesMatch>

